#!/bin/bash

# Configuration Variables
SERVICE_NAME="startpage"
DOMAIN="start.home"
PORT=80
CURRENT_DIR=$(pwd)
CURRENT_USER=$(whoami)
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"

# Check if running as root
if [ "$EUID" -ne 0 ]; then 
  echo "Please run as root (use sudo)"
  exit 1
fi

echo "Installing Startpage..."
echo "Source Directory: $CURRENT_DIR"
echo "User: $CURRENT_USER"

# 1. Create Systemd Service File
echo "Creating systemd service at $SERVICE_FILE..."
cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Local Start Page Server
After=network.target

[Service]
User=$CURRENT_USER
Group=$CURRENT_USER
WorkingDirectory=$CURRENT_DIR
ExecStart=/usr/bin/python3 -m http.server $PORT
AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

# 2. Update /etc/hosts (Idempotent: checks if entry exists first)
if grep -q "$DOMAIN" /etc/hosts; then
    echo "Domain $DOMAIN already exists in /etc/hosts. Skipping."
else
    echo "Adding $DOMAIN to /etc/hosts..."
    echo "127.0.0.1   $DOMAIN" >> /etc/hosts
fi

# 3. Enable and Start Service
echo "Enabling and starting service..."
systemctl daemon-reload
systemctl enable "$SERVICE_NAME"
systemctl restart "$SERVICE_NAME"

echo "------------------------------------------------"
echo "Success! Your start page is live at:"
echo "http://$DOMAIN"
echo "------------------------------------------------"
