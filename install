#!/bin/bash
set -euo pipefail

# Configuration Variables
SERVICE_NAME="startpage"
DOMAIN="${DOMAIN:-start.home}"
INSTALL_MODE="${INSTALL_MODE:-auto}" # auto|user|system
UPDATE_HOSTS="${UPDATE_HOSTS:-auto}" # auto|true|false
CURRENT_DIR="$(pwd)"
CURRENT_USER="$(whoami)"
HOSTS_IP="${HOSTS_IP:-127.0.0.1}"
PYTHON_BIN="$(command -v python3 || command -v python || true)"

ensure_hosts_entry() {
  local tmp_file
  tmp_file="$(mktemp)"

  awk -v d="$DOMAIN" -v ip="$HOSTS_IP" '
    BEGIN { updated = 0 }
    {
      if ($0 ~ /^[[:space:]]*#/ || NF == 0) {
        print
        next
      }

      found = 0
      kept = 0
      for (i = 2; i <= NF; i++) {
        if ($i == d) {
          found = 1
        } else {
          names[++kept] = $i
        }
      }

      if (!found) {
        print
      } else if (!updated) {
        printf "%s\t%s", ip, d
        for (i = 1; i <= kept; i++) printf " %s", names[i]
        printf "\n"
        updated = 1
      } else if (kept > 0) {
        printf "%s", $1
        for (i = 1; i <= kept; i++) printf " %s", names[i]
        printf "\n"
      }

      delete names
    }
    END {
      if (!updated) {
        print ip "\t" d
      }
    }
  ' /etc/hosts > "$tmp_file"

  cat "$tmp_file" > /etc/hosts
  rm -f "$tmp_file"
}

for arg in "$@"; do
  case "$arg" in
    --user) INSTALL_MODE="user" ;;
    --system) INSTALL_MODE="system" ;;
    --hosts) UPDATE_HOSTS="true" ;;
    --no-hosts) UPDATE_HOSTS="false" ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: $0 [--user|--system] [--hosts|--no-hosts]"
      exit 1
      ;;
  esac
done

if [ "$INSTALL_MODE" = "auto" ]; then
  if [ "$EUID" -eq 0 ]; then
    INSTALL_MODE="system"
  else
    INSTALL_MODE="user"
  fi
fi

if [ -z "${PORT:-}" ]; then
  if [ "$INSTALL_MODE" = "user" ]; then
    PORT=8000
  else
    PORT=80
  fi
fi

if [ -z "$PYTHON_BIN" ]; then
  echo "Python is required but was not found in PATH."
  exit 1
fi

echo "Installing Startpage..."
echo "Source Directory: $CURRENT_DIR"
echo "User: $CURRENT_USER"
echo "Mode: $INSTALL_MODE"
echo "Domain: $DOMAIN"

if [ "$INSTALL_MODE" = "system" ]; then
  if [ "$EUID" -ne 0 ]; then
    echo "System mode requires root. Re-run with sudo or use --user."
    exit 1
  fi

  SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
  SERVICE_USER="${SUDO_USER:-$(logname 2>/dev/null || whoami)}"
  echo "Creating systemd service at $SERVICE_FILE..."

  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Local Start Page Server
After=network.target

[Service]
User=$SERVICE_USER
Group=$SERVICE_USER
WorkingDirectory=$CURRENT_DIR
ExecStart=$PYTHON_BIN -m http.server $PORT
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

  if [ "$UPDATE_HOSTS" = "auto" ] || [ "$UPDATE_HOSTS" = "true" ]; then
    echo "Hosts entry IP: $HOSTS_IP"
    echo "Reconciling /etc/hosts entry for $DOMAIN..."
    ensure_hosts_entry
  fi

  echo "Enabling and starting service..."
  systemctl daemon-reload
  systemctl enable "$SERVICE_NAME"
  systemctl restart "$SERVICE_NAME"
else
  if [ "$EUID" -eq 0 ]; then
    echo "User mode should be run as your regular user, not root."
    exit 1
  fi

  SERVICE_DIR="$HOME/.config/systemd/user"
  SERVICE_FILE="$SERVICE_DIR/${SERVICE_NAME}.service"
  mkdir -p "$SERVICE_DIR"
  echo "Creating user service at $SERVICE_FILE..."

  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Local Start Page Server (User)
After=network.target

[Service]
WorkingDirectory=$CURRENT_DIR
ExecStart=$PYTHON_BIN -m http.server $PORT
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
EOF

  if [ "$UPDATE_HOSTS" = "true" ]; then
    echo "--hosts requested, but user mode cannot edit /etc/hosts without sudo."
  fi

  echo "Enabling and starting user service..."
  systemctl --user daemon-reload
  systemctl --user enable "$SERVICE_NAME"
  systemctl --user restart "$SERVICE_NAME"
fi

if [ "$PORT" -eq 80 ]; then
  URL="http://$DOMAIN"
else
  URL="http://$DOMAIN:$PORT"
fi

echo "------------------------------------------------"
echo "Success! Your start page is live at:"
echo "$URL"
if [ "$INSTALL_MODE" = "user" ]; then
  echo "Tip: to start user services at boot without login, run:"
  echo "sudo loginctl enable-linger $USER"
fi
echo "------------------------------------------------"
