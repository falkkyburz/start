#!/bin/bash
set -euo pipefail

SERVICE_NAME="startpage"
WEB_SERVICE="${SERVICE_NAME}.service"
UPDATE_SERVICE="${SERVICE_NAME}-update.service"
UPDATE_TIMER="${SERVICE_NAME}-update.timer"

SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
INSTALL_ROOT="$HOME/.local/share/$SERVICE_NAME"
WEB_SERVICE_FILE="$SYSTEMD_USER_DIR/$WEB_SERVICE"
UPDATE_SERVICE_FILE="$SYSTEMD_USER_DIR/$UPDATE_SERVICE"
UPDATE_TIMER_FILE="$SYSTEMD_USER_DIR/$UPDATE_TIMER"

if [ "$EUID" -eq 0 ]; then
  echo "Run this uninstaller as your regular user (no sudo)."
  exit 1
fi

echo "Uninstalling Startpage..."

systemctl --user disable --now "$UPDATE_TIMER" >/dev/null 2>&1 || true
systemctl --user stop "$UPDATE_SERVICE" >/dev/null 2>&1 || true
systemctl --user disable --now "$WEB_SERVICE" >/dev/null 2>&1 || true

for file in "$UPDATE_TIMER_FILE" "$UPDATE_SERVICE_FILE" "$WEB_SERVICE_FILE"; do
  if [ -f "$file" ]; then
    echo "Removing $(basename "$file")"
    rm "$file"
  fi
done

if [ -d "$INSTALL_ROOT" ]; then
  echo "Removing $INSTALL_ROOT"
  rm -rf "$INSTALL_ROOT"
fi

systemctl --user daemon-reload

echo "------------------------------------------------"
echo "Uninstallation complete."
echo "------------------------------------------------"
